{
  "name": "schemeweaver-webcomponents",
  "version": "1.0.0",
  "description": "Web components for Umbraco SchemeWeaver backoffice extension",
  "main": "dist/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "web-test-runner --config web-test-runner.config.mjs",
    "test:watch": "web-test-runner --config web-test-runner.config.mjs --watch",
    "test:msw": "web-test-runner --config web-test-runner.msw.config.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:screenshots": "playwright test --config=playwright.screenshots.config.ts",
    "test:mocked-backoffice": "playwright test --config=tests/mocked-backoffice/playwright.config.ts",
    "postinstall": "npx msw init . --save"
  },
  "keywords": [
    "umbraco",
    "backoffice",
    "webcomponents",
    "lit",
    "vite",
    "schema-org"
  ],
  "author": "Enjoy Digital",
  "license": "ISC",
  "devDependencies": {
    "@open-wc/testing": "^4.0.0",
    "@playwright/test": "^1.56.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.10.6",
    "@umbraco-cms/backoffice": "^17.0.0",
    "@umbraco/json-models-builders": "^2.0.42",
    "@umbraco/playwright-testhelpers": "^17.0.15",
    "@web/dev-server-esbuild": "^1.0.0",
    "@web/dev-server-import-maps": "^0.2.0",
    "@web/test-runner": "^0.18.0",
    "@web/test-runner-playwright": "^0.11.0",
    "dompurify": "^3.3.3",
    "dotenv": "^16.3.1",
    "msw": "^2.7.0",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3",
    "vite": "^8.0.8"
  },
  "overrides": {
    "dompurify": "^3.3.3"
  },
  "msw": {
    "workerDirectory": [
      ""
    ]
  }
}
