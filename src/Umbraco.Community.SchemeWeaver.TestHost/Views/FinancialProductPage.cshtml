@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<FinancialProductPage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}

@{
    var productImage = Model.Value<Umbraco.Cms.Core.Models.MediaWithCrops>("productImage");
    if (productImage != null)
    {
        var imageUrl = productImage.MediaUrl();
        if (!string.IsNullOrEmpty(imageUrl))
        {
            <img src="@imageUrl" alt="@Model.Title" class="featured-image" />
        }
    }
}

<div class="card">
    <h2>Product Details</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.InterestRate))
        {
            <dt>Interest Rate</dt>
            <dd>@Model.InterestRate%</dd>
        }
        @if (!string.IsNullOrEmpty(Model.AnnualPercentageRate))
        {
            <dt>APR</dt>
            <dd>@Model.AnnualPercentageRate</dd>
        }
        @if (!string.IsNullOrEmpty(Model.FeesAndCommissionsSpecification))
        {
            <dt>Fees &amp; Commissions</dt>
            <dd>@Model.FeesAndCommissionsSpecification</dd>
        }
    </dl>
</div>

@if (Model.BodyText != null)
{
    <div class="card">
        @Model.BodyText
    </div>
}