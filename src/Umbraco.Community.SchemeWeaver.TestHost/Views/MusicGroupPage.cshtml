@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<MusicGroupPage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}

<div class="card">
    <h2>Music Group Details</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.Genre))
        {
            <dt>Genre</dt>
            <dd>@Model.Genre</dd>
        }
        @if (!string.IsNullOrEmpty(Model.FoundingDate))
        {
            <dt>Founded</dt>
            <dd>@Model.FoundingDate</dd>
        }
    </dl>
</div>
