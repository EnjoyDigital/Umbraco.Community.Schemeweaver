@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ProfilePage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.ProfileImage))
{
    var imageUrl = Model.ProfileImage?.MediaUrl();
    if (!string.IsNullOrEmpty(imageUrl))
    {
        <img src="@imageUrl" alt="@Model.Title" class="profile-image" />
    }
}

<div class="card">
    <h2>Person Details</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.GivenName))
        {
            <dt>Given Name</dt>
            <dd>@Model.GivenName</dd>
        }
        @if (!string.IsNullOrEmpty(Model.FamilyName))
        {
            <dt>Family Name</dt>
            <dd>@Model.FamilyName</dd>
        }
        @if (!string.IsNullOrEmpty(Model.JobTitle))
        {
            <dt>Job Title</dt>
            <dd>@Model.JobTitle</dd>
        }
        @if (!string.IsNullOrEmpty(Model.Email))
        {
            <dt>Email</dt>
            <dd><a href="mailto:@Model.Email">@Model.Email</a></dd>
        }
        @if (!string.IsNullOrEmpty(Model.WorksFor))
        {
            <dt>Works For</dt>
            <dd>@Model.WorksFor</dd>
        }
    </dl>
</div>

@if (!string.IsNullOrEmpty(Model.SameAs))
{
    <div class="card">
        <h2>Social Links</h2>
        <ul class="ingredient-list">
            @foreach (var link in Model.SameAs.ToString().Split(',', System.StringSplitOptions.TrimEntries | System.StringSplitOptions.RemoveEmptyEntries))
            {
                <li><a href="@link">@link</a></li>
            }
        </ul>
    </div>
}

@if (!string.IsNullOrEmpty(Model.Description))
{
    <div class="card">
        <h2>About</h2>
        <p>@Model.Description</p>
    </div>
}