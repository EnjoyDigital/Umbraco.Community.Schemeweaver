@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<MusicEventPage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}

@{
    var heroImg = Model.Value<Umbraco.Cms.Core.Models.MediaWithCrops>("heroImage");
    if (heroImg != null)
    {
        var imageUrl = heroImg.MediaUrl();
        if (!string.IsNullOrEmpty(imageUrl))
        {
            <img src="@imageUrl" alt="@Model.Title" class="featured-image" />
        }
    }
}

<div class="card">
    <h2>Event Details</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.Performer))
        {
            <dt>Performer</dt>
            <dd>@Model.Performer</dd>
        }
        @if (Model.StartDate != default(DateTime))
        {
            <dt>Start Date</dt>
            <dd>@(Model.StartDate.ToString("d MMMM yyyy 'at' HH:mm"))</dd>
        }
        @if (Model.EndDate != default(DateTime))
        {
            <dt>End Date</dt>
            <dd>@(Model.EndDate.ToString("d MMMM yyyy 'at' HH:mm"))</dd>
        }
        @if (!string.IsNullOrEmpty(Model.LocationName))
        {
            <dt>Venue</dt>
            <dd>@Model.LocationName</dd>
        }
        @if (!string.IsNullOrEmpty(Model.LocationAddress))
        {
            <dt>Address</dt>
            <dd>@Model.LocationAddress</dd>
        }
    </dl>
</div>