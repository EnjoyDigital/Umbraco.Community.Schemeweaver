@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<HowToPage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}
@{
    var heroImg = Model.HeroImage is Umbraco.Cms.Core.Models.MediaWithCrops singleHero
        ? singleHero
        : Model.HeroImage is IEnumerable<Umbraco.Cms.Core.Models.MediaWithCrops> heroCollection
            ? heroCollection.FirstOrDefault()
            : null;
}
@if (heroImg != null)
{
    <img src="@heroImg.MediaUrl()" alt="@Model.Name" class="featured-image" />
}


@if (!string.IsNullOrEmpty(Model.TotalTime) || !string.IsNullOrEmpty(Model.EstimatedCost))
{
    <div class="meta-grid">
        @if (!string.IsNullOrEmpty(Model.TotalTime))
        {
            <div class="meta-item">
                <div class="label">Total Time</div>
                <div class="value">@Model.TotalTime</div>
            </div>
        }
        @if (!string.IsNullOrEmpty(Model.EstimatedCost))
        {
            <div class="meta-item">
                <div class="label">Estimated Cost</div>
                <div class="value">@Model.EstimatedCost</div>
            </div>
        }
    </div>
}

@if (Model.HowToSteps != null && Model.HowToSteps.Any())
{
    <div class="card">
        <h2>Steps</h2>
        <ol class="instruction-list">
            @foreach (var block in Model.HowToSteps)
            {
                if (block.Content is not HowToStep howToStep)
                {
                    continue;
                }
                <li>
                    @if (!string.IsNullOrWhiteSpace(howToStep.StepName))
                    {
                        <h3>@howToStep.StepName</h3>
                    }
                    @if (!string.IsNullOrWhiteSpace(howToStep.StepText))
                    {
                        <p>@howToStep.StepText</p>
                    }
                </li>
            }
        </ol>
    </div>
}

@if (Model.HowToTools != null && Model.HowToTools.Any())
{
    <div class="card">
        <h2>Tools Required</h2>
        <ul class="ingredient-list">
            @foreach (var block in Model.HowToTools)
            {
                if (block.Content is not HowToTool howToTool)
                {
                    continue;
                }
                <li>@howToTool.ToolName</li>
            }
        </ul>
    </div>
}