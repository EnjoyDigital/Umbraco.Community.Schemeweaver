@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<HowToPage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}

@if (Model.HeroImage != null)
{
    var imageUrl = Model.HeroImage?.MediaUrl();
    if (!string.IsNullOrEmpty(imageUrl))
    {
        <img src="@imageUrl" alt="@Model.Title" class="featured-image" />
    }
}

@if (!string.IsNullOrEmpty(Model.TotalTime) || !string.IsNullOrEmpty(Model.EstimatedCost))
{
    <div class="meta-grid">
        @if (!string.IsNullOrEmpty(Model.TotalTime))
        {
            <div class="meta-item">
                <div class="label">Total Time</div>
                <div class="value">@Model.TotalTime</div>
            </div>
        }
        @if (!string.IsNullOrEmpty(Model.EstimatedCost))
        {
            <div class="meta-item">
                <div class="label">Estimated Cost</div>
                <div class="value">@Model.EstimatedCost</div>
            </div>
        }
    </div>
}

@if (Model.Steps != null && Model.Steps.Any())
{
    <div class="card">
        <h2>Steps</h2>
        <ol class="instruction-list">
            @foreach (var block in Model.Steps)
            {
                <li>
                    @if (block.Content.HasValue("stepName"))
                    {
                        <h3>@block.Content.Value("stepName")</h3>
                    }
                    @if (block.Content.HasValue("stepText"))
                    {
                        <p>@block.Content.Value("stepText")</p>
                    }
                </li>
            }
        </ol>
    </div>
}

@if (Model.Tools != null && Model.Tools.Any())
{
    <div class="card">
        <h2>Tools Required</h2>
        <ul class="ingredient-list">
            @foreach (var block in Model.Tools)
            {
                <li>@block.Content.Value("toolName")</li>
            }
        </ul>
    </div>
}