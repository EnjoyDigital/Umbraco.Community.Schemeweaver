@using Umbraco.Cms.Web.Common.PublishedModels
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Value("title")</h1>

@if (Model.HasValue("description"))
{
    <p class="lead">@Model.Value("description")</p>
}

@if (Model.HasValue("telephone") || Model.HasValue("email"))
{
    <div class="card">
        <h2>Contact</h2>
        <dl>
            @if (Model.HasValue("telephone"))
            {
                <dt>Telephone</dt>
                <dd>@Model.Value("telephone")</dd>
            }
            @if (Model.HasValue("email"))
            {
                <dt>Email</dt>
                <dd><a href="mailto:@Model.Value("email")">@Model.Value("email")</a></dd>
            }
        </dl>
    </div>
}

@if (Model.HasValue("priceRange"))
{
    <div class="card">
        <h2>Price Range</h2>
        <p class="price-range">@Model.Value("priceRange")</p>
    </div>
}

<div class="card">
    <h2>Address</h2>
    <dl>
        @if (Model.HasValue("streetAddress"))
        {
            <dt>Street</dt>
            <dd>@Model.Value("streetAddress")</dd>
        }
        @if (Model.HasValue("addressLocality"))
        {
            <dt>Locality</dt>
            <dd>@Model.Value("addressLocality")</dd>
        }
        @if (Model.HasValue("postalCode"))
        {
            <dt>Post Code</dt>
            <dd>@Model.Value("postalCode")</dd>
        }
        @if (Model.HasValue("addressCountry"))
        {
            <dt>Country</dt>
            <dd>@Model.Value("addressCountry")</dd>
        }
    </dl>
</div>
