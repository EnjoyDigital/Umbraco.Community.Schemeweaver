@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<EventPage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}

@if (Model.EventImage != null)
{
    var imageUrl = Model.EventImage?.MediaUrl();
    if (!string.IsNullOrEmpty(imageUrl))
    {
        <img src="@imageUrl" alt="@Model.Title" />
    }
}

<div class="card">
    <h2>Event Details</h2>
    <dl>
        @if (Model.StartDate != default)
        {
            <dt>Start Date</dt>
            <dd>@(Model.StartDate.ToString("d MMMM yyyy 'at' HH:mm"))</dd>
        }
        @if (Model.EndDate != default)
        {
            <dt>End Date</dt>
            <dd>@(Model.EndDate.ToString("d MMMM yyyy 'at' HH:mm"))</dd>
        }
        @if (!string.IsNullOrEmpty(Model.EventStatus))
        {
            <dt>Status</dt>
            <dd>@Model.EventStatus</dd>
        }
        @if (!string.IsNullOrEmpty(Model.EventAttendanceMode))
        {
            <dt>Attendance Mode</dt>
            <dd>@Model.EventAttendanceMode</dd>
        }
    </dl>
</div>

<div class="card">
    <h2>Venue</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.LocationName))
        {
            <dt>Location</dt>
            <dd>@Model.LocationName</dd>
        }
        @if (!string.IsNullOrEmpty(Model.LocationAddress))
        {
            <dt>Address</dt>
            <dd>@Model.LocationAddress</dd>
        }
    </dl>
</div>

@if (!string.IsNullOrEmpty(Model.OrganiserName))
{
    <div class="card">
        <h2>Organiser</h2>
        <dl>
            <dt>Organised by</dt>
            <dd>@Model.OrganiserName</dd>
        </dl>
    </div>
}

@if (!string.IsNullOrEmpty(Model.TicketPrice) || !string.IsNullOrEmpty(Model.TicketCurrency) || !string.IsNullOrEmpty(Model.TicketUrl))
{
    <div class="card">
        <h2>Tickets</h2>
        <dl>
            @if (!string.IsNullOrEmpty(Model.TicketPrice))
            {
                <dt>Price</dt>
                <dd>
                    @if (!string.IsNullOrEmpty(Model.TicketCurrency))
                    {
                        @Model.TicketCurrency
                    }
                    @Model.TicketPrice
                </dd>
            }
            @if (!string.IsNullOrEmpty(Model.TicketUrl))
            {
                <dt>Book Tickets</dt>
                <dd><a href="@Model.TicketUrl" class="btn">Buy tickets</a></dd>
            }
        </dl>
    </div>
}