@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<TechArticle>
@{
    Layout = "Master.cshtml";
}
<article>
    <h1>@Model.Title</h1>
@if (Model.HeroImage != null)
{
    <img src="@Model.HeroImage.MediaUrl()" alt="@Model.HeroImage.Name" class="featured-image" />
}

    <div class="article-meta">
        @if (!string.IsNullOrEmpty(Model.AuthorName))
        {
            <span>By @Model.AuthorName</span>
        }
        @if (Model.PublishDate != default(DateTime))
        {
            <span> &middot; @(Model.PublishDate.ToString("d MMMM yyyy"))</span>
        }
    </div>

    @if (!string.IsNullOrEmpty(Model.ProficiencyLevel) || !string.IsNullOrEmpty(Model.Dependencies))
    {
        <div class="card">
            <h2>Technical Details</h2>
            <dl>
                @if (!string.IsNullOrEmpty(Model.ProficiencyLevel))
                {
                    <dt>Proficiency Level</dt>
                    <dd>@Model.ProficiencyLevel</dd>
                }
                @if (!string.IsNullOrEmpty(Model.Dependencies))
                {
                    <dt>Dependencies</dt>
                    <dd>@Model.Dependencies</dd>
                }
            </dl>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.Description))
    {
        <p class="lead">@Model.Description</p>
    }
    @if (Model.BodyText != null)
    {
        <div class="card">
            @Model.BodyText
        </div>
    }
</article>