@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<MusicRecordingPage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}
@{
    var heroImg = Model.Value<Umbraco.Cms.Core.Models.MediaWithCrops>("heroImage");
}
@if (heroImg != null)
{
    <img src="@heroImg.MediaUrl()" alt="@Model.Name" class="featured-image" />
}


@if (!string.IsNullOrEmpty(Model.ByArtist) || !string.IsNullOrEmpty(Model.InAlbum) || !string.IsNullOrEmpty(Model.Duration) || Model.DatePublished != default(DateTime))
{
    <div class="card">
        <h2>Recording Details</h2>
        <dl>
            @if (!string.IsNullOrEmpty(Model.ByArtist))
            {
                <dt>Artist</dt>
                <dd>@Model.ByArtist</dd>
            }
            @if (!string.IsNullOrEmpty(Model.InAlbum))
            {
                <dt>Album</dt>
                <dd>@Model.InAlbum</dd>
            }
            @if (!string.IsNullOrEmpty(Model.Duration))
            {
                <dt>Duration</dt>
                <dd>@Model.Duration</dd>
            }
            @if (Model.DatePublished != default(DateTime))
            {
                <dt>Date Published</dt>
                <dd>@(Model.DatePublished.ToString("d MMMM yyyy"))</dd>
            }
        </dl>
    </div>
}