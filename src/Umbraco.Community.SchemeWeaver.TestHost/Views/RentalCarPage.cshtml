@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<RentalCarPage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}
@{
    var heroImg = Model.Value<Umbraco.Cms.Core.Models.MediaWithCrops>("heroImage");
}
@if (heroImg != null)
{
    <img src="@heroImg.MediaUrl()" alt="@Model.Name" class="featured-image" />
}


<div class="card">
    <h2>Rental Details</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.ReservationId))
        {
            <dt>Reservation ID</dt>
            <dd>@Model.ReservationId</dd>
        }
        @if (!string.IsNullOrEmpty(Model.PickupLocation))
        {
            <dt>Pick-up Location</dt>
            <dd>@Model.PickupLocation</dd>
        }
        @if (Model.PickupTime != default(DateTime))
        {
            <dt>Pick-up Time</dt>
            <dd>@(Model.PickupTime.ToString("d MMMM yyyy 'at' HH:mm"))</dd>
        }
    </dl>
</div>