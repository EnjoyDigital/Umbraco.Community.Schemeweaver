@using Umbraco.Cms.Core.Models.Blocks
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<HomePage>
@{
    Layout = "Master.cshtml";
    var siteName = Model.SiteName;
    var siteDescription = Model.SiteDescription;
    var contentGrid = Model.ContentGrid;
}

<h1>@siteName</h1>

@if (!string.IsNullOrEmpty(siteDescription))
{
    <p class="lead">@siteDescription</p>
}

@if (contentGrid is not null && contentGrid.Any())
{
    <section class="content-grid">
        @foreach (var item in contentGrid)
        {
            <div class="grid-item grid-item--@item.Content.ContentType.Alias">
                @if (item.Content is HeroBlock heroBlock)
                {
                    if (heroBlock.HeroImage != null)
                    {
                        <img src="@heroBlock.HeroImage.MediaUrl()" alt="@heroBlock.HeroImage.Name" class="block-hero-image" />
                    }
                    <h2>@heroBlock.Title</h2>
                    <p>@heroBlock.Subtitle</p>
                }
                else if (item.Content is FeatureBlock featureBlock)
                {
                    if (featureBlock.FeatureImage != null)
                    {
                        <img src="@featureBlock.FeatureImage.MediaUrl()" alt="@featureBlock.FeatureImage.Name" class="block-feature-image" />
                    }
                    <h3>@featureBlock.Title</h3>
                    <div class="feature-description">@featureBlock.Description</div>
                }
                else if (item.Content is QuoteBlock quoteBlock)
                {
                    <blockquote>
                        <p>&ldquo;@quoteBlock.Quote&rdquo;</p>
                        <cite>&mdash; @quoteBlock.Attribution</cite>
                    </blockquote>
                }
            </div>
        }
    </section>
}

<h2>Explore Our Site</h2>
@{
    var children = Model.Children?.ToList();
}
@if (children != null && children.Any())
{
    <div class="card-grid">
        @foreach (var child in children)
        {
            <div class="card">
                <h3><a href="@child.Url()">@child.Name</a></h3>
                @{
                    var childDescription = child.GetTypedDescription();
                }
                @if (!string.IsNullOrWhiteSpace(childDescription))
                {
                    <p>@childDescription</p>
                }
                else
                {
                    <p><span class="tag">@child.ContentType.Alias</span></p>
                }
            </div>
        }
    </div>
}