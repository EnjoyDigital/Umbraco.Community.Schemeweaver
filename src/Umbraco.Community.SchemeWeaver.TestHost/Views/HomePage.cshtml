@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<HomePage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.SiteName</h1>

@if (!string.IsNullOrEmpty(Model.SiteDescription))
{
    <p class="lead">@Model.SiteDescription</p>
}

@if (!string.IsNullOrEmpty(Model.OrganisationName) || !string.IsNullOrEmpty(Model.OrganisationEmail) || !string.IsNullOrEmpty(Model.OrganisationTelephone))
{
    <div class="card">
        <h2>Organisation</h2>
        <dl>
            @if (!string.IsNullOrEmpty(Model.OrganisationName))
            {
                <dt>Name</dt>
                <dd>@Model.OrganisationName</dd>
            }
            @if (!string.IsNullOrEmpty(Model.OrganisationEmail))
            {
                <dt>Email</dt>
                <dd><a href="mailto:@Model.OrganisationEmail">@Model.OrganisationEmail</a></dd>
            }
            @if (!string.IsNullOrEmpty(Model.OrganisationTelephone))
            {
                <dt>Telephone</dt>
                <dd>@Model.OrganisationTelephone</dd>
            }
        </dl>
    </div>
}

<h2>Explore Our Site</h2>
@if (Model.Children != null && Model.Children.Any())
{
    <div class="card-grid">
        @foreach (var child in Model.Children)
        {
            <div class="card">
                <h3><a href="@child.Url()">@child.Name</a></h3>
                @if (child.HasValue("description"))
                {
                    <p>@child.Value("description")</p>
                }
                else
                {
                    <p><span class="tag">@child.ContentType.Alias</span></p>
                }
            </div>
        }
    </div>
}