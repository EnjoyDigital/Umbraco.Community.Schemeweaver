@using Umbraco.Cms.Core.Models.Blocks
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@{
    Layout = "Master.cshtml";
    var siteName = Model.Value<string>("siteName");
    var siteDescription = Model.Value<string>("siteDescription");
    var contentGrid = Model.Value<BlockGridModel>("contentGrid");
}

<h1>@siteName</h1>

@if (!string.IsNullOrEmpty(siteDescription))
{
    <p class="lead">@siteDescription</p>
}

@if (contentGrid is not null && contentGrid.Any())
{
    <section class="content-grid">
        @foreach (var item in contentGrid)
        {
            var block = item.Content;
            var alias = block.ContentType.Alias;
            var title = (block.Value("title") as string) ?? string.Empty;
            <div class="grid-item grid-item--@alias">
                @if (alias == "heroBlock")
                {
                    var blockHero = block.Value<IEnumerable<Umbraco.Cms.Core.Models.MediaWithCrops>>("heroImage")?.FirstOrDefault();
                    if (blockHero is not null)
                    {
                        <img src="@blockHero.MediaUrl()" alt="@title" class="block-hero-image" />
                    }
                    <h2>@title</h2>
                    <p>@(block.Value("subtitle"))</p>
                }
                else if (alias == "featureBlock")
                {
                    var blockImg = block.Value<IEnumerable<Umbraco.Cms.Core.Models.MediaWithCrops>>("featureImage")?.FirstOrDefault();
                    if (blockImg is not null)
                    {
                        <img src="@blockImg.MediaUrl()" alt="@title" class="block-feature-image" />
                    }
                    <h3>@title</h3>
                    <div class="feature-description">@(block.Value("description"))</div>
                }
                else if (alias == "quoteBlock")
                {
                    var quote = (block.Value("quote") as string) ?? string.Empty;
                    var attribution = (block.Value("attribution") as string) ?? string.Empty;
                    <blockquote>
                        <p>&ldquo;@quote&rdquo;</p>
                        <cite>&mdash; @attribution</cite>
                    </blockquote>
                }
            </div>
        }
    </section>
}

<h2>Explore Our Site</h2>
@{
    var children = Model.Children?.Where(c => c.ContentType.Alias != "landingPage").ToList();
}
@if (children != null && children.Any())
{
    <div class="card-grid">
        @foreach (var child in children)
        {
            <div class="card">
                <h3><a href="@child.Url()">@child.Name</a></h3>
                @if (child.HasValue("description"))
                {
                    <p>@child.Value("description")</p>
                }
                else
                {
                    <p><span class="tag">@child.ContentType.Alias</span></p>
                }
            </div>
        }
    </div>
}
