@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<RealEstateListingPage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}

@if (!string.IsNullOrEmpty(Model.Price) || !string.IsNullOrEmpty(Model.PriceCurrency) || Model.DatePosted != default(DateTime))
{
    <div class="card">
        <h2>Listing Details</h2>
        <dl>
            @if (!string.IsNullOrEmpty(Model.Price))
            {
                <dt>Price</dt>
                <dd>
                    @Model.Price
                    @if (!string.IsNullOrEmpty(Model.PriceCurrency))
                    {
                        <span>@Model.PriceCurrency</span>
                    }
                </dd>
            }
            @if (Model.DatePosted != default(DateTime))
            {
                <dt>Date Posted</dt>
                <dd>@(Model.DatePosted.ToString("d MMMM yyyy"))</dd>
            }
        </dl>
    </div>
}

<div class="card">
    <h2>Address</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.StreetAddress))
        {
            <dt>Street</dt>
            <dd>@Model.StreetAddress</dd>
        }
        @if (!string.IsNullOrEmpty(Model.AddressLocality))
        {
            <dt>Locality</dt>
            <dd>@Model.AddressLocality</dd>
        }
        @if (!string.IsNullOrEmpty(Model.PostalCode))
        {
            <dt>Post Code</dt>
            <dd>@Model.PostalCode</dd>
        }
        @if (!string.IsNullOrEmpty(Model.AddressCountry))
        {
            <dt>Country</dt>
            <dd>@Model.AddressCountry</dd>
        }
    </dl>
</div>