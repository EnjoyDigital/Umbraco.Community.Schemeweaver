@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<CorporationPage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}

<div class="card">
    <h2>Company Details</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.LegalName))
        {
            <dt>Legal Name</dt>
            <dd>@Model.LegalName</dd>
        }
        @if (!string.IsNullOrEmpty(Model.TickerSymbol))
        {
            <dt>Ticker Symbol</dt>
            <dd>@Model.TickerSymbol</dd>
        }
        @if (!string.IsNullOrEmpty(Model.FoundingDate))
        {
            <dt>Founded</dt>
            <dd>@Model.FoundingDate</dd>
        }
        @if (!string.IsNullOrEmpty(Model.NumberOfEmployees))
        {
            <dt>Employees</dt>
            <dd>@Model.NumberOfEmployees</dd>
        }
    </dl>
</div>