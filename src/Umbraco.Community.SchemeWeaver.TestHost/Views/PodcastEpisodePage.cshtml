@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<PodcastEpisodePage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}

<div class="card">
    <h2>Episode Details</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.Duration))
        {
            <dt>Duration</dt>
            <dd>@Model.Duration</dd>
        }
        @if (!string.IsNullOrEmpty(Model.DatePublished))
        {
            <dt>Published</dt>
            <dd>@(((DateTime)Model.DatePublished).ToString("d MMMM yyyy"))</dd>
        }
    </dl>
</div>
