@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<SoftwarePage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}

<div class="card">
    <h2>Software Details</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.ApplicationCategory))
        {
            <dt>Category</dt>
            <dd>@Model.ApplicationCategory</dd>
        }
        @if (!string.IsNullOrEmpty(Model.OperatingSystem))
        {
            <dt>Operating System</dt>
            <dd>@Model.OperatingSystem</dd>
        }
        @if (!string.IsNullOrEmpty(Model.SoftwareVersion))
        {
            <dt>Version</dt>
            <dd>@Model.SoftwareVersion</dd>
        }
        @if (!string.IsNullOrEmpty(Model.DownloadUrl))
        {
            <dt>Download</dt>
            <dd><a href="@Model.DownloadUrl" class="btn">Download</a></dd>
        }
    </dl>
</div>

@if (!string.IsNullOrEmpty(Model.Price) || !string.IsNullOrEmpty(Model.Currency))
{
    <div class="card">
        <h2>Pricing</h2>
        <p class="price">
            @if (!string.IsNullOrEmpty(Model.Currency))
            {
                @Model.Currency
            }
            @Model.Price
        </p>
    </div>
}

@if (Model.BodyText != null)
{
    <div class="card">
        @Model.BodyText
    </div>
}