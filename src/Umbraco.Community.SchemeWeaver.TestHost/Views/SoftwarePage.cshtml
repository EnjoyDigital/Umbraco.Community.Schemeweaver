@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<SoftwarePage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}

@if (!string.IsNullOrEmpty(Model.SoftwareImage))
{
    var imageUrl = Model.SoftwareImage?.MediaUrl();
    if (!string.IsNullOrEmpty(imageUrl))
    {
        <img src="@imageUrl" alt="@Model.Title" />
    }
}

<div class="card">
    <h2>Software Details</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.ApplicationCategory))
        {
            <dt>Category</dt>
            <dd>@Model.ApplicationCategory</dd>
        }
        @if (!string.IsNullOrEmpty(Model.OperatingSystem))
        {
            <dt>Operating System</dt>
            <dd>@Model.OperatingSystem</dd>
        }
        @if (!string.IsNullOrEmpty(Model.SoftwareVersion))
        {
            <dt>Version</dt>
            <dd>@Model.SoftwareVersion</dd>
        }
        @if (!string.IsNullOrEmpty(Model.DownloadUrl))
        {
            <dt>Download</dt>
            <dd><a href="@Model.DownloadUrl" class="btn">Download</a></dd>
        }
    </dl>
</div>

@if (!string.IsNullOrEmpty(Model.Price) || !string.IsNullOrEmpty(Model.Currency))
{
    <div class="card">
        <h2>Pricing</h2>
        <p class="price">
            @if (!string.IsNullOrEmpty(Model.Currency))
            {
                @Model.Currency
            }
            @Model.Price
        </p>
    </div>
}

@if (!string.IsNullOrEmpty(Model.BodyText))
{
    <div class="card">
        @Model.BodyText
    </div>
}

@if (!string.IsNullOrEmpty(Model.Reviews))
{
    <h2>Reviews</h2>
    @foreach (var block in Model.Reviews)
    {
        <div class="card review-card">
            <strong>@block.Content.Value("reviewAuthor")</strong>
            <span> &middot; Rating: @block.Content.Value("ratingValue")/5</span>
            @if (block.Content.HasValue("reviewDate"))
            {
                <span> &middot; @(((DateTime)block.Content.Value("reviewDate")).ToString("d MMMM yyyy"))</span>
            }
            <p>@block.Content.Value("reviewBody")</p>
        </div>
    }
}