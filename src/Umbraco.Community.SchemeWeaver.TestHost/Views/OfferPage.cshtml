@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<OfferPage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}

@if (!string.IsNullOrEmpty(Model.Price) || !string.IsNullOrEmpty(Model.PriceCurrency) || !string.IsNullOrEmpty(Model.Availability))
{
    <div class="card">
        <h2>Offer Details</h2>
        <dl>
            @if (!string.IsNullOrEmpty(Model.Price))
            {
                <dt>Price</dt>
                <dd>
                    @Model.Price
                    @if (!string.IsNullOrEmpty(Model.PriceCurrency))
                    {
                        <span>@Model.PriceCurrency</span>
                    }
                </dd>
            }
            @if (!string.IsNullOrEmpty(Model.Availability))
            {
                <dt>Availability</dt>
                <dd>@Model.Availability</dd>
            }
            @if (!string.IsNullOrEmpty(Model.ItemOffered))
            {
                <dt>Item Offered</dt>
                <dd>@Model.ItemOffered</dd>
            }
        </dl>
    </div>
}

@if (!string.IsNullOrEmpty(Model.ValidFrom) || !string.IsNullOrEmpty(Model.ValidThrough))
{
    <div class="card">
        <h2>Validity</h2>
        <dl>
            @if (!string.IsNullOrEmpty(Model.ValidFrom))
            {
                <dt>Valid From</dt>
                <dd>@Model.ValidFrom</dd>
            }
            @if (!string.IsNullOrEmpty(Model.ValidThrough))
            {
                <dt>Valid Through</dt>
                <dd>@Model.ValidThrough</dd>
            }
        </dl>
    </div>
}
