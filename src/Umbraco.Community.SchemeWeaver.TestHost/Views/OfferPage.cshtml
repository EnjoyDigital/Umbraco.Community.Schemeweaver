@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<OfferPage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}

@if (Model.HeroImage != null)
{
    <img src="@Model.HeroImage.MediaUrl()" alt="@Model.HeroImage.Name" class="featured-image" />
}

@if (!string.IsNullOrEmpty(Model.Price) || !string.IsNullOrEmpty(Model.PriceCurrency) || !string.IsNullOrEmpty(Model.Availability))
{
    <div class="card">
        <h2>Offer Details</h2>
        <dl>
            @if (!string.IsNullOrEmpty(Model.Price))
            {
                <dt>Price</dt>
                <dd>
                    @Model.Price
                    @if (!string.IsNullOrEmpty(Model.PriceCurrency))
                    {
                        <span>@Model.PriceCurrency</span>
                    }
                </dd>
            }
            @if (!string.IsNullOrEmpty(Model.Availability))
            {
                <dt>Availability</dt>
                <dd>@Model.Availability</dd>
            }
            @if (!string.IsNullOrEmpty(Model.ItemOffered))
            {
                <dt>Item Offered</dt>
                <dd>@Model.ItemOffered</dd>
            }
        </dl>
    </div>
}

@if (Model.ValidFrom != default(DateTime) || Model.ValidThrough != default(DateTime))
{
    <div class="card">
        <h2>Validity</h2>
        <dl>
            @if (Model.ValidFrom != default(DateTime))
            {
                <dt>Valid From</dt>
                <dd>@(Model.ValidFrom.ToString("d MMMM yyyy"))</dd>
            }
            @if (Model.ValidThrough != default(DateTime))
            {
                <dt>Valid Through</dt>
                <dd>@(Model.ValidThrough.ToString("d MMMM yyyy"))</dd>
            }
        </dl>
    </div>
}