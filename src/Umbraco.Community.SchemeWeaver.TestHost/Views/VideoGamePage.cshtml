@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<VideoGamePage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}

<div class="card">
    <h2>Game Details</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.GamePlatform))
        {
            <dt>Platform</dt>
            <dd>@Model.GamePlatform</dd>
        }
        @if (!string.IsNullOrEmpty(Model.Genre))
        {
            <dt>Genre</dt>
            <dd>@Model.Genre</dd>
        }
    </dl>
</div>