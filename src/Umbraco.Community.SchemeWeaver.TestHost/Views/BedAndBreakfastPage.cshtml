@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<BedAndBreakfastPage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}

<div class="card">
    <h2>B&amp;B Details</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.CheckinTime))
        {
            <dt>Check-in</dt>
            <dd>@Model.CheckinTime</dd>
        }
        @if (!string.IsNullOrEmpty(Model.CheckoutTime))
        {
            <dt>Check-out</dt>
            <dd>@Model.CheckoutTime</dd>
        }
        @if (!string.IsNullOrEmpty(Model.Telephone))
        {
            <dt>Telephone</dt>
            <dd>@Model.Telephone</dd>
        }
    </dl>
</div>

<div class="card">
    <h2>Address</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.StreetAddress))
        {
            <dt>Street</dt>
            <dd>@Model.StreetAddress</dd>
        }
        @if (!string.IsNullOrEmpty(Model.AddressLocality))
        {
            <dt>Locality</dt>
            <dd>@Model.AddressLocality</dd>
        }
    </dl>
</div>
