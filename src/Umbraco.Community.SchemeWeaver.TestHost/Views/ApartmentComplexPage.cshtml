@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ApartmentComplexPage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}

@if (!string.IsNullOrEmpty(Model.NumberOfAccommodationUnits) || !string.IsNullOrEmpty(Model.PetsAllowed) || !string.IsNullOrEmpty(Model.Telephone))
{
    <div class="card">
        <h2>Complex Details</h2>
        <dl>
            @if (!string.IsNullOrEmpty(Model.NumberOfAccommodationUnits))
            {
                <dt>Number of Units</dt>
                <dd>@Model.NumberOfAccommodationUnits</dd>
            }
            @if (!string.IsNullOrEmpty(Model.PetsAllowed))
            {
                <dt>Pets Allowed</dt>
                <dd>@Model.PetsAllowed</dd>
            }
            @if (!string.IsNullOrEmpty(Model.Telephone))
            {
                <dt>Telephone</dt>
                <dd>@Model.Telephone</dd>
            }
        </dl>
    </div>
}

<div class="card">
    <h2>Address</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.StreetAddress))
        {
            <dt>Street</dt>
            <dd>@Model.StreetAddress</dd>
        }
        @if (!string.IsNullOrEmpty(Model.AddressLocality))
        {
            <dt>Locality</dt>
            <dd>@Model.AddressLocality</dd>
        }
        @if (!string.IsNullOrEmpty(Model.PostalCode))
        {
            <dt>Post Code</dt>
            <dd>@Model.PostalCode</dd>
        }
        @if (!string.IsNullOrEmpty(Model.AddressCountry))
        {
            <dt>Country</dt>
            <dd>@Model.AddressCountry</dd>
        }
    </dl>
</div>