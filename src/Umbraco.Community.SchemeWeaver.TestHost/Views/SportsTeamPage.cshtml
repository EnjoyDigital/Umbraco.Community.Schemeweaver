@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<SportsTeamPage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}
@if (Model.HeroImage != null)
{
    <img src="@Model.HeroImage.MediaUrl()" alt="@Model.HeroImage.Name" class="featured-image" />
}


<div class="card">
    <h2>Team Details</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.Sport))
        {
            <dt>Sport</dt>
            <dd>@Model.Sport</dd>
        }
        @if (!string.IsNullOrEmpty(Model.Coach))
        {
            <dt>Coach</dt>
            <dd>@Model.Coach</dd>
        }
    </dl>
</div>