@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<OrganisationParent>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}

@if (!string.IsNullOrEmpty(Model.Telephone) || !string.IsNullOrEmpty(Model.Email))
{
    <div class="card">
        <h2>Contact</h2>
        <dl>
            @if (!string.IsNullOrEmpty(Model.Telephone))
            {
                <dt>Telephone</dt>
                <dd>@Model.Telephone</dd>
            }
            @if (!string.IsNullOrEmpty(Model.Email))
            {
                <dt>Email</dt>
                <dd><a href="mailto:@Model.Email">@Model.Email</a></dd>
            }
        </dl>
    </div>
}

<div class="card">
    <h2>Address</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.StreetAddress))
        {
            <dt>Street</dt>
            <dd>@Model.StreetAddress</dd>
        }
        @if (!string.IsNullOrEmpty(Model.AddressLocality))
        {
            <dt>Locality</dt>
            <dd>@Model.AddressLocality</dd>
        }
        @if (!string.IsNullOrEmpty(Model.PostalCode))
        {
            <dt>Post Code</dt>
            <dd>@Model.PostalCode</dd>
        }
        @if (!string.IsNullOrEmpty(Model.AddressCountry))
        {
            <dt>Country</dt>
            <dd>@Model.AddressCountry</dd>
        }
    </dl>
</div>

<h2>Departments &amp; Subsidiaries</h2>
@if (Model.Children != null && Model.Children.Any())
{
    <div class="card-grid">
        @foreach (var child in Model.Children)
        {
            <div class="card">
                <h3><a href="@child.Url()">@child.Name</a></h3>
                @if (child.HasValue("description"))
                {
                    <p>@child.Value("description")</p>
                }
                else
                {
                    <p><span class="tag">@child.ContentType.Alias</span></p>
                }
            </div>
        }
    </div>
}
else
{
    <p>No child organisations found.</p>
}