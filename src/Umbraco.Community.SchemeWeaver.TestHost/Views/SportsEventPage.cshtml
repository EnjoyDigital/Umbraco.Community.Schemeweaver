@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<SportsEventPage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}

@{
    var eventImage = Model.Value<Umbraco.Cms.Core.Models.MediaWithCrops>("eventImage");
    if (eventImage != null)
    {
        var imageUrl = eventImage.MediaUrl();
        if (!string.IsNullOrEmpty(imageUrl))
        {
            <img src="@imageUrl" alt="@Model.Title" class="featured-image" />
        }
    }
}

<div class="card">
    <h2>Match Details</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.Competitor))
        {
            <dt>Opponent</dt>
            <dd>@Model.Competitor</dd>
        }
        @if (!string.IsNullOrEmpty(Model.Sport))
        {
            <dt>Sport</dt>
            <dd>@Model.Sport</dd>
        }
        @if (Model.StartDate != default(DateTime))
        {
            <dt>Kick-off</dt>
            <dd>@(Model.StartDate.ToString("d MMMM yyyy 'at' HH:mm"))</dd>
        }
        @if (!string.IsNullOrEmpty(Model.LocationName))
        {
            <dt>Venue</dt>
            <dd>@Model.LocationName</dd>
        }
    </dl>
</div>