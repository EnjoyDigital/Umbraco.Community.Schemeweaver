@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<BookPage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (Model.BookImage != null)
{
    var imageUrl = Model.BookImage?.MediaUrl();
    if (!string.IsNullOrEmpty(imageUrl))
    {
        <img src="@imageUrl" alt="@Model.Title" class="constrained-image" />
    }
}

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}

<div class="card">
    <h2>Book Details</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.AuthorName))
        {
            <dt>Author</dt>
            <dd>@Model.AuthorName</dd>
        }
        @if (!string.IsNullOrEmpty(Model.Isbn))
        {
            <dt>ISBN</dt>
            <dd>@Model.Isbn</dd>
        }
        @if (!string.IsNullOrEmpty(Model.BookFormat))
        {
            <dt>Format</dt>
            <dd>@Model.BookFormat</dd>
        }
        @if (!string.IsNullOrEmpty(Model.NumberOfPages))
        {
            <dt>Pages</dt>
            <dd>@Model.NumberOfPages</dd>
        }
        @if (!string.IsNullOrEmpty(Model.Publisher))
        {
            <dt>Publisher</dt>
            <dd>@Model.Publisher</dd>
        }
        @if (Model.DatePublished != default)
        {
            <dt>Published</dt>
            <dd>@(Model.DatePublished.ToString("d MMMM yyyy"))</dd>
        }
    </dl>
</div>

@if (!string.IsNullOrEmpty(Model.Price))
{
    <div class="card">
        <h2>Price</h2>
        <p class="price">
            @if (!string.IsNullOrEmpty(Model.Currency))
            {
                @Model.Currency
            }
            @Model.Price
        </p>
    </div>
}

@if (!string.IsNullOrEmpty(Model.BodyText))
{
    <div class="card">
        @Model.BodyText
    </div>
}