@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<AboutPage>
@{
    Layout = "Master.cshtml";
}
<article>
    <h1>@Model.Title</h1>
@{
    var heroImg = Model.Value<Umbraco.Cms.Core.Models.MediaWithCrops>("heroImage");
}
@if (heroImg != null)
{
    <img src="@heroImg.MediaUrl()" alt="@Model.Name" class="featured-image" />
}


    @if (!string.IsNullOrEmpty(Model.Description))
    {
        <p class="lead">@Model.Description</p>
    }

    @if (Model.BodyText != null)
    {
        <div class="card">
            @Model.BodyText
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.OrganisationName) || !string.IsNullOrEmpty(Model.FoundingDate) || !string.IsNullOrEmpty(Model.NumberOfEmployees))
    {
        <div class="card">
            <h2>Organisation Details</h2>
            <dl>
                @if (!string.IsNullOrEmpty(Model.OrganisationName))
                {
                    <dt>Organisation</dt>
                    <dd>@Model.OrganisationName</dd>
                }
                @if (!string.IsNullOrEmpty(Model.FoundingDate))
                {
                    <dt>Founded</dt>
                    <dd>@Model.FoundingDate</dd>
                }
                @if (!string.IsNullOrEmpty(Model.NumberOfEmployees))
                {
                    <dt>Employees</dt>
                    <dd>@Model.NumberOfEmployees</dd>
                }
            </dl>
        </div>
    }
</article>