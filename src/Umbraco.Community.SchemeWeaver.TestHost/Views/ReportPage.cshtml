@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ReportPage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}
@if (Model.HeroImage != null)
{
    <img src="@Model.HeroImage.MediaUrl()" alt="@Model.HeroImage.Name" class="featured-image" />
}


<div class="card">
    <h2>Report Details</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.AuthorName))
        {
            <dt>Author</dt>
            <dd>@Model.AuthorName</dd>
        }
        @if (Model.PublishDate != default(DateTime))
        {
            <dt>Published</dt>
            <dd>@(Model.PublishDate.ToString("d MMMM yyyy"))</dd>
        }
    </dl>
</div>