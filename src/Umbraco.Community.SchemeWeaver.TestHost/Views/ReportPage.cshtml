@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ReportPage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}

<div class="card">
    <h2>Report Details</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.AuthorName))
        {
            <dt>Author</dt>
            <dd>@Model.AuthorName</dd>
        }
        @if (!string.IsNullOrEmpty(Model.PublishDate))
        {
            <dt>Published</dt>
            <dd>@(((DateTime)Model.PublishDate).ToString("d MMMM yyyy"))</dd>
        }
    </dl>
</div>
