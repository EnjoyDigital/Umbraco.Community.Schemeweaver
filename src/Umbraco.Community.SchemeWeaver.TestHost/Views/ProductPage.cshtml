@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ProductPage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>
@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}

@{
    var heroImg = Model.HeroImage is Umbraco.Cms.Core.Models.MediaWithCrops singleHero
        ? singleHero
        : Model.HeroImage is IEnumerable<Umbraco.Cms.Core.Models.MediaWithCrops> heroCollection
            ? heroCollection.FirstOrDefault()
            : null;
}
@if (heroImg != null)
{
    <img src="@heroImg.MediaUrl()" alt="@Model.Name" class="featured-image" />
}

<div class="card">
    <dl>
        @if (!string.IsNullOrEmpty(Model.Price))
        {
            <dt>Price</dt>
            <dd>@Model.Price @Model.Currency</dd>
        }
        @if (!string.IsNullOrEmpty(Model.Sku))
        {
            <dt>SKU</dt>
            <dd>@Model.Sku</dd>
        }
        @if (!string.IsNullOrEmpty(Model.Brand))
        {
            <dt>Brand</dt>
            <dd>@Model.Brand</dd>
        }
        @if (!string.IsNullOrEmpty(Model.Availability))
        {
            <dt>Availability</dt>
            <dd>@Model.Availability</dd>
        }
    </dl>
</div>

@if (Model.BodyText is not null)
{
    <div class="card">
        @Model.BodyText
    </div>
}

@if (Model.Reviews?.Any() == true)
{
    <h2>Customer Reviews</h2>
    @foreach (var block in Model.Reviews)
    {
        var author = block.Content.Value("author") as string;
        var ratingValue = block.Content.Value("ratingValue");
        var datePublished = block.Content.Value<DateTime?>("datePublished");
        var reviewBody = block.Content.Value("reviewBody") as string;
        <div class="card review-card">
            <strong>@author</strong>
            <span> &middot; Rating: @ratingValue/5</span>
            @if (datePublished.HasValue && datePublished.Value != default)
            {
                <span> &middot; @(datePublished.Value.ToString("d MMMM yyyy"))</span>
            }
            <p>@reviewBody</p>
        </div>
    }
}