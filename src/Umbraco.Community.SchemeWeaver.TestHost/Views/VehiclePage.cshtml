@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<VehiclePage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}

<div class="card">
    <h2>Vehicle Details</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.Brand))
        {
            <dt>Brand</dt>
            <dd>@Model.Brand</dd>
        }
        @if (!string.IsNullOrEmpty(Model.Model))
        {
            <dt>Model</dt>
            <dd>@Model.Model</dd>
        }
        @if (!string.IsNullOrEmpty(Model.FuelType))
        {
            <dt>Fuel Type</dt>
            <dd>@Model.FuelType</dd>
        }
        @if (!string.IsNullOrEmpty(Model.MileageFromOdometer))
        {
            <dt>Mileage</dt>
            <dd>@Model.MileageFromOdometer</dd>
        }
        @if (!string.IsNullOrEmpty(Model.VehicleEngine))
        {
            <dt>Engine</dt>
            <dd>@Model.VehicleEngine</dd>
        }
        @if (!string.IsNullOrEmpty(Model.Color))
        {
            <dt>Colour</dt>
            <dd>@Model.Color</dd>
        }
        @if (!string.IsNullOrEmpty(Model.NumberOfDoors))
        {
            <dt>Doors</dt>
            <dd>@Model.NumberOfDoors</dd>
        }
    </dl>
</div>

@if (Model.BodyText != null)
{
    <div class="card">
        @Model.BodyText
    </div>
}