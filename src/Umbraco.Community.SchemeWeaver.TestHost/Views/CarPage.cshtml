@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<CarPage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}
@{
    var heroImg = Model.Value<Umbraco.Cms.Core.Models.MediaWithCrops>("heroImage");
}
@if (heroImg != null)
{
    <img src="@heroImg.MediaUrl()" alt="@Model.Name" class="featured-image" />
}


<div class="card">
    <h2>Car Details</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.Brand))
        {
            <dt>Brand</dt>
            <dd>@Model.Brand</dd>
        }
        @if (!string.IsNullOrEmpty(Model.Model))
        {
            <dt>Model</dt>
            <dd>@Model.Model</dd>
        }
        @if (!string.IsNullOrEmpty(Model.FuelType))
        {
            <dt>Fuel Type</dt>
            <dd>@Model.FuelType</dd>
        }
        @if (!string.IsNullOrEmpty(Model.MileageFromOdometer))
        {
            <dt>Mileage</dt>
            <dd>@Model.MileageFromOdometer</dd>
        }
        @if (!string.IsNullOrEmpty(Model.Color))
        {
            <dt>Colour</dt>
            <dd>@Model.Color</dd>
        }
        @if (!string.IsNullOrEmpty(Model.NumberOfDoors))
        {
            <dt>Doors</dt>
            <dd>@Model.NumberOfDoors</dd>
        }
        @if (!string.IsNullOrEmpty(Model.VehicleTransmission))
        {
            <dt>Transmission</dt>
            <dd>@Model.VehicleTransmission</dd>
        }
    </dl>
</div>