@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<FaqPage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>
@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}
@if (Model.HeroImage != null)
{
    <img src="@Model.HeroImage.MediaUrl()" alt="@Model.HeroImage.Name" class="featured-image" />
}


@if (Model.FaqItems != null && Model.FaqItems.Any())
{
    <div class="faq-list">
        @foreach (var block in Model.FaqItems)
        {
            if (block.Content is not FaqItem faqItem)
            {
                continue;
            }
            <div class="card faq-item">
                <h3 class="faq-question">@faqItem.Question</h3>
                <div class="faq-answer">@faqItem.Answer</div>
            </div>
        }
    </div>
}