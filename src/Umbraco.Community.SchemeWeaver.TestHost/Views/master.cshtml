@using Umbraco.Cms.Web.Common.PublishedModels
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="@System.Threading.Thread.CurrentThread.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@Model.Name — SchemeWeaver Demo</title>
    <scheme-weaver content="@Model" />
    <link rel="icon" href="/favicon.ico" type="image/x-icon" />
    <link href="https://fonts.googleapis.com/css2?family=VT323&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/c64-theme.css" />
</head>
<body>
    <a class="skip-link" href="#main">Skip to main content</a>
    <header>
        <div class="container">
            @{
                var cultures = new[] { ("en-US", "EN"), ("de-DE", "DE") };
                var currentCulture = System.Threading.Thread.CurrentThread.CurrentUICulture.Name;
            }
            <div class="lang-switcher">
                @foreach (var (culture, label) in cultures)
                {
                    var url = Model.Url(culture: culture);
                    var isActive = currentCulture.StartsWith(culture.Split('-')[0]);
                    <a href="@(url ?? "#")" class="@(isActive ? "active" : "")">@label</a>
                }
            </div>
            <div class="boot-text">
                <div>**** SCHEMEWEAVER DEMO V1.0 ****</div>
                <div>64K RAM SYSTEM  38911 BASIC BYTES FREE</div>
                <div>READY.<span class="cursor">&#9608;</span></div>
            </div>
            <nav class="site-nav">
                <a href="/" class="site-title @(Model.Root()?.Id == Model.Id ? "active" : "")">HOME</a>
                @{
                    var rootChildren = Model.Root()?.Children;
                    if (rootChildren != null)
                    {
                        foreach (var child in rootChildren)
                        {
                            <a href="@child.Url()" class="@(child.IsAncestorOrSelf(Model) ? "active" : "")">@child.Name</a>
                        }
                    }
                }
            </nav>
        </div>
    </header>
    <main id="main">
        <div class="container">
            @{
                var trail = Model.AncestorsOrSelf().Reverse().ToList();
            }
            @if (trail.Count > 1)
            {
                <nav class="breadcrumbs" aria-label="Breadcrumb">
                    <ol>
                        @for (var i = 0; i < trail.Count; i++)
                        {
                            var crumb = trail[i];
                            var isLast = i == trail.Count - 1;
                            <li>
                                @if (i > 0)
                                {
                                    <span class="breadcrumb-separator" aria-hidden="true">&gt;</span>
                                }
                                @if (isLast)
                                {
                                    <span aria-current="page">@crumb.Name</span>
                                }
                                else
                                {
                                    <a href="@crumb.Url()">@crumb.Name</a>
                                }
                            </li>
                        }
                    </ol>
                </nav>
            }
            @RenderBody()
        </div>
    </main>
    <footer>
        <div class="container">
            <p>LOAD "*",8,1 &mdash; &copy; @DateTime.Now.Year SCHEMEWEAVER DEMO &mdash; STRUCTURED DATA WITH UMBRACO</p>
        </div>
    </footer>
</body>
</html>