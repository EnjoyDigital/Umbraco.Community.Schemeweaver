@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<WebAppPage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}

<div class="card">
    <h2>Web App Details</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.BrowserRequirements))
        {
            <dt>Browser Requirements</dt>
            <dd>@Model.BrowserRequirements</dd>
        }
        @if (!string.IsNullOrEmpty(Model.ApplicationCategory))
        {
            <dt>Category</dt>
            <dd>@Model.ApplicationCategory</dd>
        }
        @if (!string.IsNullOrEmpty(Model.Url))
        {
            <dt>URL</dt>
            <dd><a href="@Model.Url">@Model.Url</a></dd>
        }
    </dl>
</div>