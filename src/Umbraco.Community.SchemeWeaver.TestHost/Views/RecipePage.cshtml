@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<RecipePage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}

@if (!string.IsNullOrEmpty(Model.AuthorName))
{
    <p>By <strong>@Model.AuthorName</strong></p>
}

@{
    var heroImg = Model.Value<Umbraco.Cms.Core.Models.MediaWithCrops>("heroImage");
}
@if (heroImg != null)
{
    <img src="@heroImg.MediaUrl()" alt="@Model.Name" class="featured-image" />
}

<div class="card">
    <h2>Details</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.PrepTime))
        {
            <dt>Prep Time</dt>
            <dd>@Model.PrepTime</dd>
        }
        @if (!string.IsNullOrEmpty(Model.CookTime))
        {
            <dt>Cook Time</dt>
            <dd>@Model.CookTime</dd>
        }
        @if (!string.IsNullOrEmpty(Model.TotalTime))
        {
            <dt>Total Time</dt>
            <dd>@Model.TotalTime</dd>
        }
        @if (!string.IsNullOrEmpty(Model.RecipeYield))
        {
            <dt>Yield</dt>
            <dd>@Model.RecipeYield</dd>
        }
        @if (!string.IsNullOrEmpty(Model.Calories))
        {
            <dt>Calories</dt>
            <dd>@Model.Calories</dd>
        }
        @if (!string.IsNullOrEmpty(Model.RecipeCategory))
        {
            <dt>Category</dt>
            <dd>@Model.RecipeCategory</dd>
        }
        @if (!string.IsNullOrEmpty(Model.RecipeCuisine))
        {
            <dt>Cuisine</dt>
            <dd>@Model.RecipeCuisine</dd>
        }
    </dl>
</div>

@if (Model.Ingredients?.Any() == true)
{
    <div class="card">
        <h2>Ingredients</h2>
        <ul class="ingredient-list">
            @foreach (var block in Model.Ingredients)
            {
                <li>@block.Content.Value("ingredient")</li>
            }
        </ul>
    </div>
}

@if (Model.Instructions?.Any() == true)
{
    <div class="card">
        <h2>Instructions</h2>
        <ol class="instruction-list">
            @foreach (var block in Model.Instructions)
            {
                <li>
                    @if (block.Content.HasValue("stepName"))
                    {
                        <strong>@block.Content.Value("stepName")</strong><br />
                    }
                    @block.Content.Value("stepText")
                </li>
            }
        </ol>
    </div>
}