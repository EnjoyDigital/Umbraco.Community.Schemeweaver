@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<CoursePage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}
@{
    var heroImg = Model.Value<Umbraco.Cms.Core.Models.MediaWithCrops>("heroImage");
}
@if (heroImg != null)
{
    <img src="@heroImg.MediaUrl()" alt="@Model.Name" class="featured-image" />
}


<div class="card">
    <h2>Course Details</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.CourseCode))
        {
            <dt>Course Code</dt>
            <dd>@Model.CourseCode</dd>
        }
        @if (!string.IsNullOrEmpty(Model.ProviderName))
        {
            <dt>Provider</dt>
            <dd>@Model.ProviderName</dd>
        }
        @if (!string.IsNullOrEmpty(Model.Duration))
        {
            <dt>Duration</dt>
            <dd>@Model.Duration</dd>
        }
        @if (Model.StartDate != default)
        {
            <dt>Start Date</dt>
            <dd>@(Model.StartDate.ToString("d MMMM yyyy"))</dd>
        }
    </dl>
</div>

@if (!string.IsNullOrEmpty(Model.Price))
{
    <div class="card">
        <p class="price">
            @if (!string.IsNullOrEmpty(Model.Currency))
            {
                @Model.Currency
            }
            @Model.Price
        </p>
        <a href="#enrol" class="btn">Enrol Now</a>
    </div>
}

@if (Model.BodyText != null)
{
    <div class="card">
        @Model.BodyText
    </div>
}