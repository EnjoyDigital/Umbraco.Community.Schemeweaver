@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<CoursePage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}

@if (Model.CourseImage != null)
{
    var imageUrl = Model.CourseImage?.MediaUrl();
    if (!string.IsNullOrEmpty(imageUrl))
    {
        <img src="@imageUrl" alt="@Model.Title" />
    }
}

<div class="card">
    <h2>Course Details</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.CourseCode))
        {
            <dt>Course Code</dt>
            <dd>@Model.CourseCode</dd>
        }
        @if (!string.IsNullOrEmpty(Model.Provider))
        {
            <dt>Provider</dt>
            <dd>@Model.Provider</dd>
        }
        @if (!string.IsNullOrEmpty(Model.Duration))
        {
            <dt>Duration</dt>
            <dd>@Model.Duration</dd>
        }
        @if (Model.StartDate != default)
        {
            <dt>Start Date</dt>
            <dd>@(Model.StartDate.ToString("d MMMM yyyy"))</dd>
        }
    </dl>
</div>

@if (!string.IsNullOrEmpty(Model.Price))
{
    <div class="card">
        <p class="price">
            @if (!string.IsNullOrEmpty(Model.Currency))
            {
                @Model.Currency
            }
            @Model.Price
        </p>
        <a href="#enrol" class="btn">Enrol Now</a>
    </div>
}

@if (!string.IsNullOrEmpty(Model.BodyText))
{
    <div class="card">
        @Model.BodyText
    </div>
}