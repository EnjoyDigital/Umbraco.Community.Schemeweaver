@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ArticlePage>
@{
    Layout = "Master.cshtml";
}
<article>
    <h1>@Model.Title</h1>
@if (Model.HeroImage != null)
{
    <img src="@Model.HeroImage.MediaUrl()" alt="@Model.HeroImage.Name" class="featured-image" />
}


    @if (!string.IsNullOrEmpty(Model.AuthorName) || Model.DatePublished != default(DateTime))
    {
        <p class="article-meta">
            @if (!string.IsNullOrEmpty(Model.AuthorName))
            {
                <span>By @Model.AuthorName</span>
            }
            @if (Model.DatePublished != default(DateTime))
            {
                <span> &mdash; @(Model.DatePublished.ToString("d MMMM yyyy"))</span>
            }
        </p>
    }

    @if (!string.IsNullOrEmpty(Model.Description))
    {
        <p class="lead">@Model.Description</p>
    }

    @if (Model.BodyText != null)
    {
        <div class="card">
            @Html.Raw(Model.BodyText)
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ArticleSection) || !string.IsNullOrEmpty(Model.WordCount))
    {
        <div class="card">
            <h2>Article Details</h2>
            <dl>
                @if (!string.IsNullOrEmpty(Model.ArticleSection))
                {
                    <dt>Section</dt>
                    <dd>@Model.ArticleSection</dd>
                }
                @if (!string.IsNullOrEmpty(Model.WordCount))
                {
                    <dt>Word Count</dt>
                    <dd>@Model.WordCount</dd>
                }
            </dl>
        </div>
    }
</article>