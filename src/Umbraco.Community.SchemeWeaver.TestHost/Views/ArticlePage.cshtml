@using Umbraco.Cms.Web.Common.PublishedModels
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@{
    Layout = "Master.cshtml";
}
<article>
    <h1>@Model.Value("title")</h1>

    @if (Model.HasValue("authorName") || Model.HasValue("datePublished"))
    {
        <p class="article-meta">
            @if (Model.HasValue("authorName"))
            {
                <span>By @Model.Value("authorName")</span>
            }
            @if (Model.HasValue("datePublished"))
            {
                <span> &mdash; @Model.Value("datePublished")</span>
            }
        </p>
    }

    @if (Model.HasValue("description"))
    {
        <p class="lead">@Model.Value("description")</p>
    }

    @if (Model.HasValue("bodyText"))
    {
        <div class="card">
            @Html.Raw(Model.Value("bodyText"))
        </div>
    }

    @if (Model.HasValue("articleSection") || Model.HasValue("wordCount"))
    {
        <div class="card">
            <h2>Article Details</h2>
            <dl>
                @if (Model.HasValue("articleSection"))
                {
                    <dt>Section</dt>
                    <dd>@Model.Value("articleSection")</dd>
                }
                @if (Model.HasValue("wordCount"))
                {
                    <dt>Word Count</dt>
                    <dd>@Model.Value("wordCount")</dd>
                }
            </dl>
        </div>
    }
</article>
