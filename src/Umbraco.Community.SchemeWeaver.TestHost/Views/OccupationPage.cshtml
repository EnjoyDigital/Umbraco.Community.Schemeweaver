@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<OccupationPage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}

<div class="card">
    <h2>Occupation Details</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.OccupationalCategory))
        {
            <dt>Category</dt>
            <dd>@Model.OccupationalCategory</dd>
        }
        @if (!string.IsNullOrEmpty(Model.EstimatedSalary))
        {
            <dt>Estimated Salary</dt>
            <dd>@Model.EstimatedSalary</dd>
        }
        @if (!string.IsNullOrEmpty(Model.Skills))
        {
            <dt>Skills</dt>
            <dd>@Model.Skills</dd>
        }
    </dl>
</div>