@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<LodgingReservationPage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}

<div class="card">
    <h2>Reservation Details</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.ReservationId))
        {
            <dt>Reservation ID</dt>
            <dd>@Model.ReservationId</dd>
        }
        @if (Model.CheckinTime != default(DateTime))
        {
            <dt>Check-in</dt>
            <dd>@(Model.CheckinTime.ToString("d MMMM yyyy HH:mm"))</dd>
        }
        @if (Model.CheckoutTime != default(DateTime))
        {
            <dt>Check-out</dt>
            <dd>@(Model.CheckoutTime.ToString("d MMMM yyyy HH:mm"))</dd>
        }
    </dl>
</div>