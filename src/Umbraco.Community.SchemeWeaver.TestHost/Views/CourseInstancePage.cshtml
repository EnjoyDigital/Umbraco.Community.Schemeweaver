@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<CourseInstancePage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}

<div class="card">
    <h2>Course Instance Details</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.StartDate))
        {
            <dt>Start Date</dt>
            <dd>@Model.StartDate</dd>
        }
        @if (!string.IsNullOrEmpty(Model.EndDate))
        {
            <dt>End Date</dt>
            <dd>@Model.EndDate</dd>
        }
        @if (!string.IsNullOrEmpty(Model.Instructor))
        {
            <dt>Instructor</dt>
            <dd>@Model.Instructor</dd>
        }
    </dl>
</div>
