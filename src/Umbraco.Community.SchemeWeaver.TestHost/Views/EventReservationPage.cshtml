@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<EventReservationPage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}
@{
    var heroImg = Model.Value<Umbraco.Cms.Core.Models.MediaWithCrops>("heroImage");
}
@if (heroImg != null)
{
    <img src="@heroImg.MediaUrl()" alt="@Model.Name" class="featured-image" />
}


<div class="card">
    <h2>Reservation Details</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.ReservationId))
        {
            <dt>Reservation ID</dt>
            <dd>@Model.ReservationId</dd>
        }
        @if (!string.IsNullOrEmpty(Model.ReservationFor))
        {
            <dt>Reservation For</dt>
            <dd>@Model.ReservationFor</dd>
        }
    </dl>
</div>