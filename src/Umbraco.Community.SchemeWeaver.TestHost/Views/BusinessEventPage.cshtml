@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<BusinessEventPage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}

@{
    var eventImage = Model.Value<Umbraco.Cms.Core.Models.MediaWithCrops>("eventImage");
    if (eventImage != null)
    {
        var imageUrl = eventImage.MediaUrl();
        if (!string.IsNullOrEmpty(imageUrl))
        {
            <img src="@imageUrl" alt="@Model.Title" class="featured-image" />
        }
    }
}

<div class="card">
    <h2>Event Details</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.OrganiserName))
        {
            <dt>Organiser</dt>
            <dd>@Model.OrganiserName</dd>
        }
        @if (Model.StartDate != default)
        {
            <dt>Date</dt>
            <dd>@(Model.StartDate.ToString("d MMMM yyyy 'at' HH:mm"))</dd>
        }
        @if (!string.IsNullOrEmpty(Model.LocationName))
        {
            <dt>Venue</dt>
            <dd>@Model.LocationName</dd>
        }
        @if (!string.IsNullOrEmpty(Model.Sponsor))
        {
            <dt>Sponsor</dt>
            <dd>@Model.Sponsor</dd>
        }
    </dl>
</div>