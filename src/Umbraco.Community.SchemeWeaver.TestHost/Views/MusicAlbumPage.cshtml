@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<MusicAlbumPage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}

<div class="card">
    <h2>Album Details</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.ByArtist))
        {
            <dt>Artist</dt>
            <dd>@Model.ByArtist</dd>
        }
        @if (!string.IsNullOrEmpty(Model.NumTracks))
        {
            <dt>Tracks</dt>
            <dd>@Model.NumTracks</dd>
        }
        @if (!string.IsNullOrEmpty(Model.DatePublished))
        {
            <dt>Released</dt>
            <dd>@(((DateTime)Model.DatePublished).ToString("d MMMM yyyy"))</dd>
        }
    </dl>
</div>
