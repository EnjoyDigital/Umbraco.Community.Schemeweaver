@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<EducationListing>
@{
    Layout = "Master.cshtml";
    var categories = Model.Children?.Where(c => c.ContentType.Alias.EndsWith("Listing")) ?? Enumerable.Empty<IPublishedContent>();
    var items = Model.Children?.Where(c => !c.ContentType.Alias.EndsWith("Listing")) ?? Enumerable.Empty<IPublishedContent>();
    var parentIsListing = Model.Parent?.ContentType.Alias.EndsWith("Listing") == true;
}

@if (parentIsListing)
{
    <nav class="breadcrumb" aria-label="Breadcrumb">
        @foreach (var ancestor in Model.Ancestors().Reverse())
        {
            if (ancestor.ContentType.Alias.EndsWith("Listing"))
            {
                <a href="@ancestor.Url()">@ancestor.Name</a>
                <span class="breadcrumb-sep">&rsaquo;</span>
            }
        }
        <span class="breadcrumb-current">@Model.Name</span>
    </nav>
}

<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}
@if (Model.HeroImage != null)
{
    <img src="@Model.HeroImage.MediaUrl()" alt="@Model.HeroImage.Name" class="featured-image" />
}


@if (categories.Any())
{
    <h2>Categories</h2>
    <div class="card-grid">
        @foreach (var child in categories)
        {
            <div class="card category-card">
                <h3><a href="@child.Url()">@child.Name</a></h3>
                @{
                    var childDescription = child.GetTypedDescription();
                }
                @if (!string.IsNullOrWhiteSpace(childDescription))
                {
                    <p>@childDescription</p>
                }
            </div>
        }
    </div>
}

@if (items.Any())
{
    if (categories.Any())
    {
        <h2>Items</h2>
    }
    <div class="card-grid">
        @foreach (var child in items)
        {
            <div class="card">
                <h3><a href="@child.Url()">@child.Name</a></h3>
                @{
                    var childDescription = child.GetTypedDescription();
                }
                @if (!string.IsNullOrWhiteSpace(childDescription))
                {
                    <p>@childDescription</p>
                }
            </div>
        }
    </div>
}