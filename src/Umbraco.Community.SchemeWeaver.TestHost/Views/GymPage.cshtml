@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<GymPage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}

<div class="card">
    <h2>Gym Details</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.Telephone))
        {
            <dt>Telephone</dt>
            <dd>@Model.Telephone</dd>
        }
        @if (Model.OpeningHours?.Any() == true)
        {
            <dt>Opening Hours</dt>
            <dd>@Model.OpeningHours</dd>
        }
    </dl>
</div>

<div class="card">
    <h2>Address</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.StreetAddress))
        {
            <dt>Street</dt>
            <dd>@Model.StreetAddress</dd>
        }
        @if (!string.IsNullOrEmpty(Model.AddressLocality))
        {
            <dt>Locality</dt>
            <dd>@Model.AddressLocality</dd>
        }
    </dl>
</div>