@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<FlightReservationPage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}

<div class="card">
    <h2>Reservation Details</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.ReservationId))
        {
            <dt>Reservation ID</dt>
            <dd>@Model.ReservationId</dd>
        }
        @if (!string.IsNullOrEmpty(Model.FlightNumber))
        {
            <dt>Flight Number</dt>
            <dd>@Model.FlightNumber</dd>
        }
        @if (!string.IsNullOrEmpty(Model.DepartureAirport))
        {
            <dt>Departure Airport</dt>
            <dd>@Model.DepartureAirport</dd>
        }
        @if (!string.IsNullOrEmpty(Model.ArrivalAirport))
        {
            <dt>Arrival Airport</dt>
            <dd>@Model.ArrivalAirport</dd>
        }
    </dl>
</div>