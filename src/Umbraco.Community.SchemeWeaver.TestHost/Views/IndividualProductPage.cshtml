@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<IndividualProductPage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}

@if (Model.HeroImage != null)
{
    <img src="@Model.HeroImage.MediaUrl()" alt="@Model.HeroImage.Name" class="featured-image" />
}

<div class="card">
    <h2>Product Details</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.SerialNumber))
        {
            <dt>Serial Number</dt>
            <dd>@Model.SerialNumber</dd>
        }
        @if (!string.IsNullOrEmpty(Model.Sku))
        {
            <dt>SKU</dt>
            <dd>@Model.Sku</dd>
        }
        @if (!string.IsNullOrEmpty(Model.Color))
        {
            <dt>Colour</dt>
            <dd>@Model.Color</dd>
        }
        @if (!string.IsNullOrEmpty(Model.Weight))
        {
            <dt>Weight</dt>
            <dd>@Model.Weight</dd>
        }
    </dl>
    @if (Model.ProductImage != null)
    {
        <img src="@Model.ProductImage.MediaUrl()" alt="@Model.ProductImage.Name" class="content-image" />
    }
</div>

@if (Model.BodyText != null)
{
    <div class="card">
        @Model.BodyText
    </div>
}