@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ScreeningEventPage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}

<div class="card">
    <h2>Screening Details</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.Performer))
        {
            <dt>Performer</dt>
            <dd>@Model.Performer</dd>
        }
        @if (!string.IsNullOrEmpty(Model.StartDate))
        {
            <dt>Start Date</dt>
            <dd>@Model.StartDate</dd>
        }
        @if (!string.IsNullOrEmpty(Model.LocationName))
        {
            <dt>Venue</dt>
            <dd>@Model.LocationName</dd>
        }
    </dl>
</div>
