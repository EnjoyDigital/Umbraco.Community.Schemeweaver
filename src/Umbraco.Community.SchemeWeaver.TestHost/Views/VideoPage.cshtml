@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<VideoPage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}

@if (!string.IsNullOrEmpty(Model.EmbedUrl))
{
    <div class="video-embed">
        <iframe src="@Model.EmbedUrl" allowfullscreen></iframe>
    </div>
}
else if (!string.IsNullOrEmpty(Model.ThumbnailUrl))
{
    var thumbUrl = Model.ThumbnailUrl?.MediaUrl();
    if (!string.IsNullOrEmpty(thumbUrl))
    {
        <img src="@thumbUrl" alt="@Model.Title" class="featured-image" />
    }
}

<div class="card">
    <h2>Video Details</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.UploadDate))
        {
            <dt>Upload Date</dt>
            <dd>@(((DateTime)Model.UploadDate).ToString("d MMMM yyyy"))</dd>
        }
        @if (!string.IsNullOrEmpty(Model.Duration))
        {
            <dt>Duration</dt>
            <dd>@Model.Duration</dd>
        }
        @if (!string.IsNullOrEmpty(Model.ContentUrl))
        {
            <dt>Video URL</dt>
            <dd><a href="@Model.ContentUrl">@Model.ContentUrl</a></dd>
        }
    </dl>
</div>