@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ServicePage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}
@if (Model.HeroImage != null)
{
    <img src="@Model.HeroImage.MediaUrl()" alt="@Model.HeroImage.Name" class="featured-image" />
}


@if (!string.IsNullOrEmpty(Model.ServiceType) || !string.IsNullOrEmpty(Model.Provider) || !string.IsNullOrEmpty(Model.AreaServed))
{
    <div class="card">
        <h2>Service Details</h2>
        <dl>
            @if (!string.IsNullOrEmpty(Model.ServiceType))
            {
                <dt>Service Type</dt>
                <dd>@Model.ServiceType</dd>
            }
            @if (!string.IsNullOrEmpty(Model.Provider))
            {
                <dt>Provider</dt>
                <dd>@Model.Provider</dd>
            }
            @if (!string.IsNullOrEmpty(Model.AreaServed))
            {
                <dt>Area Served</dt>
                <dd>@Model.AreaServed</dd>
            }
        </dl>
    </div>
}

@if (!string.IsNullOrEmpty(Model.Price))
{
    <div class="card">
        <h2>Pricing</h2>
        <p class="price-range">@Model.Price</p>
    </div>
}