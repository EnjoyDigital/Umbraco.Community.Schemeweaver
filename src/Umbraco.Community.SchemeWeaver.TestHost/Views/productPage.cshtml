@using Umbraco.Cms.Web.Common.PublishedModels
@using Umbraco.Cms.Core.Models.Blocks
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Value("title")</h1>
@if (Model.HasValue("description"))
{
    <p class="lead">@Model.Value("description")</p>
}

@{
    var productImage = Model.Value<Umbraco.Cms.Core.Models.MediaWithCrops>("productImage");
}
@if (productImage != null)
{
    <img src="@productImage.MediaUrl()" alt="@Model.Value("title")" />
}

<div class="card">
    <dl>
        @if (Model.HasValue("price"))
        {
            <dt>Price</dt>
            <dd>@Model.Value("price") @Model.Value("currency")</dd>
        }
        @if (Model.HasValue("sku"))
        {
            <dt>SKU</dt>
            <dd>@Model.Value("sku")</dd>
        }
        @if (Model.HasValue("brand"))
        {
            <dt>Brand</dt>
            <dd>@Model.Value("brand")</dd>
        }
        @if (Model.HasValue("availability"))
        {
            <dt>Availability</dt>
            <dd>@Model.Value("availability")</dd>
        }
    </dl>
</div>

@if (Model.HasValue("bodyText"))
{
    <div class="card">
        @Model.Value("bodyText")
    </div>
}

@if (Model.HasValue("reviews"))
{
    <h2>Customer Reviews</h2>
    @foreach (var block in Model.Value<BlockListModel>("reviews"))
    {
        <div class="card review-card">
            <strong>@block.Content.Value("author")</strong>
            <span> &middot; Rating: @block.Content.Value("ratingValue")/5</span>
            @if (block.Content.HasValue("datePublished"))
            {
                <span> &middot; @(((DateTime)block.Content.Value("datePublished")).ToString("d MMMM yyyy"))</span>
            }
            <p>@block.Content.Value("reviewBody")</p>
        </div>
    }
}