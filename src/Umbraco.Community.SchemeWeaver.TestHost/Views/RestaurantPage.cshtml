@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<RestaurantPage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}

@if (!string.IsNullOrEmpty(Model.LocationImage))
{
    var imageUrl = Model.LocationImage?.MediaUrl();
    if (!string.IsNullOrEmpty(imageUrl))
    {
        <img src="@imageUrl" alt="@Model.Title" />
    }
}

@if (!string.IsNullOrEmpty(Model.ServesCuisine) || !string.IsNullOrEmpty(Model.MenuUrl) || !string.IsNullOrEmpty(Model.AcceptsReservations))
{
    <div class="card">
        <h2>Restaurant Details</h2>
        <dl>
            @if (!string.IsNullOrEmpty(Model.ServesCuisine))
            {
                <dt>Cuisine</dt>
                <dd>@Model.ServesCuisine</dd>
            }
            @if (!string.IsNullOrEmpty(Model.MenuUrl))
            {
                <dt>Menu</dt>
                <dd><a href="@Model.MenuUrl">View Menu</a></dd>
            }
            @if (!string.IsNullOrEmpty(Model.AcceptsReservations))
            {
                <dt>Reservations</dt>
                <dd>@Model.AcceptsReservations</dd>
            }
        </dl>
    </div>
}

@if (!string.IsNullOrEmpty(Model.Telephone) || !string.IsNullOrEmpty(Model.Email))
{
    <div class="card">
        <h2>Contact</h2>
        <dl>
            @if (!string.IsNullOrEmpty(Model.Telephone))
            {
                <dt>Telephone</dt>
                <dd>@Model.Telephone</dd>
            }
            @if (!string.IsNullOrEmpty(Model.Email))
            {
                <dt>Email</dt>
                <dd><a href="mailto:@Model.Email">@Model.Email</a></dd>
            }
        </dl>
    </div>
}

<div class="card">
    <h2>Address</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.StreetAddress))
        {
            <dt>Street</dt>
            <dd>@Model.StreetAddress</dd>
        }
        @if (!string.IsNullOrEmpty(Model.AddressLocality))
        {
            <dt>Locality</dt>
            <dd>@Model.AddressLocality</dd>
        }
        @if (!string.IsNullOrEmpty(Model.AddressRegion))
        {
            <dt>Region</dt>
            <dd>@Model.AddressRegion</dd>
        }
        @if (!string.IsNullOrEmpty(Model.PostalCode))
        {
            <dt>Post Code</dt>
            <dd>@Model.PostalCode</dd>
        }
        @if (!string.IsNullOrEmpty(Model.AddressCountry))
        {
            <dt>Country</dt>
            <dd>@Model.AddressCountry</dd>
        }
    </dl>
</div>

@if (!string.IsNullOrEmpty(Model.Latitude) || !string.IsNullOrEmpty(Model.Longitude))
{
    <div class="card">
        <h2>Coordinates</h2>
        <dl>
            @if (!string.IsNullOrEmpty(Model.Latitude))
            {
                <dt>Latitude</dt>
                <dd>@Model.Latitude</dd>
            }
            @if (!string.IsNullOrEmpty(Model.Longitude))
            {
                <dt>Longitude</dt>
                <dd>@Model.Longitude</dd>
            }
        </dl>
    </div>
}

@if (!string.IsNullOrEmpty(Model.OpeningHours))
{
    <div class="card">
        <h2>Opening Hours</h2>
        @foreach (var block in Model.OpeningHours)
        {
            <p>
                <strong>@block.Content.Value("dayOfWeek")</strong>:
                @block.Content.Value("opens") &ndash; @block.Content.Value("closes")
            </p>
        }
    </div>
}

@if (!string.IsNullOrEmpty(Model.PriceRange))
{
    <div class="card">
        <h2>Price Range</h2>
        <p class="price-range">@Model.PriceRange</p>
    </div>
}