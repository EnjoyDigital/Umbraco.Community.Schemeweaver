@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContactPage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

<div class="card">
    <dl>
        @if (!string.IsNullOrEmpty(Model.Telephone))
        {
            <dt>Telephone</dt>
            <dd>@Model.Telephone</dd>
        }
        @if (!string.IsNullOrEmpty(Model.Email))
        {
            <dt>Email</dt>
            <dd><a href="mailto:@Model.Email">@Model.Email</a></dd>
        }
        @if (!string.IsNullOrEmpty(Model.StreetAddress))
        {
            <dt>Address</dt>
            <dd>
                @Model.StreetAddress<br />
                @Model.AddressLocality @Model.PostalCode
            </dd>
        }
        @if (!string.IsNullOrEmpty(Model.OpeningHours))
        {
            <dt>Opening Hours</dt>
            <dd>@Model.OpeningHours</dd>
        }
    </dl>
</div>