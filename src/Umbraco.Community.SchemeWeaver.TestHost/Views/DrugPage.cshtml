@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<DrugPage>
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Title</h1>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="lead">@Model.Description</p>
}

<div class="card">
    <h2>Drug Details</h2>
    <dl>
        @if (!string.IsNullOrEmpty(Model.ActiveIngredient))
        {
            <dt>Active Ingredient</dt>
            <dd>@Model.ActiveIngredient</dd>
        }
        @if (!string.IsNullOrEmpty(Model.DosageForm))
        {
            <dt>Dosage Form</dt>
            <dd>@Model.DosageForm</dd>
        }
    </dl>
</div>