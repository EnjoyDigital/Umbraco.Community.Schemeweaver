@using Umbraco.Cms.Web.Common.PublishedModels
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Value("title")</h1>

@if (Model.HasValue("description"))
{
    <p class="lead">@Model.Value("description")</p>
}

<div class="card">
    <h2>App Details</h2>
    <dl>
        @if (Model.HasValue("operatingSystem"))
        {
            <dt>Operating System</dt>
            <dd>@Model.Value("operatingSystem")</dd>
        }
        @if (Model.HasValue("applicationCategory"))
        {
            <dt>Category</dt>
            <dd>@Model.Value("applicationCategory")</dd>
        }
        @if (Model.HasValue("softwareVersion"))
        {
            <dt>Version</dt>
            <dd>@Model.Value("softwareVersion")</dd>
        }
        @if (Model.HasValue("downloadUrl"))
        {
            <dt>Download</dt>
            <dd><a href="@Model.Value("downloadUrl")" class="btn">Download</a></dd>
        }
    </dl>
</div>
