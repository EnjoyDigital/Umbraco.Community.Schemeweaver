@using Umbraco.Cms.Web.Common.PublishedModels
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@{
    Layout = "Master.cshtml";
}
<article>
    <h1>@Model.Value("title")</h1>
    <div class="article-meta">
        @if (Model.HasValue("authorName"))
        {
            <span>By @Model.Value("authorName")</span>
        }
        @if (Model.HasValue("publishDate"))
        {
            <span> &middot; @(((DateTime)Model.Value("publishDate")).ToString("d MMMM yyyy"))</span>
        }
    </div>
    @if (Model.HasValue("description"))
    {
        <p class="lead">@Model.Value("description")</p>
    }
    @if (Model.HasValue("bodyText"))
    {
        <div class="card">
            @Model.Value("bodyText")
        </div>
    }
</article>
