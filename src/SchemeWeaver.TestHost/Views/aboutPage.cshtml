@using Umbraco.Cms.Web.Common.PublishedModels
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@{
    Layout = "Master.cshtml";
}
<article>
    <h1>@Model.Value("title")</h1>

    @if (Model.HasValue("heroImage"))
    {
        var imageUrl = Model.Value<Umbraco.Cms.Core.Models.MediaWithCrops>("heroImage")?.MediaUrl();
        if (!string.IsNullOrEmpty(imageUrl))
        {
            <img src="@imageUrl" alt="@Model.Value("title")" class="featured-image" />
        }
    }

    @if (Model.HasValue("description"))
    {
        <p class="lead">@Model.Value("description")</p>
    }

    @if (Model.HasValue("bodyText"))
    {
        <div class="card">
            @Model.Value("bodyText")
        </div>
    }

    @if (Model.HasValue("organisationName") || Model.HasValue("foundingDate") || Model.HasValue("numberOfEmployees"))
    {
        <div class="card">
            <h2>Organisation Details</h2>
            <dl>
                @if (Model.HasValue("organisationName"))
                {
                    <dt>Organisation</dt>
                    <dd>@Model.Value("organisationName")</dd>
                }
                @if (Model.HasValue("foundingDate"))
                {
                    <dt>Founded</dt>
                    <dd>@Model.Value("foundingDate")</dd>
                }
                @if (Model.HasValue("numberOfEmployees"))
                {
                    <dt>Employees</dt>
                    <dd>@Model.Value("numberOfEmployees")</dd>
                }
            </dl>
        </div>
    }
</article>
