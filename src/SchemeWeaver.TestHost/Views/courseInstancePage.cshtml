@using Umbraco.Cms.Web.Common.PublishedModels
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Value("title")</h1>

@if (Model.HasValue("description"))
{
    <p class="lead">@Model.Value("description")</p>
}

<div class="card">
    <h2>Course Instance Details</h2>
    <dl>
        @if (Model.HasValue("startDate"))
        {
            <dt>Start Date</dt>
            <dd>@Model.Value("startDate")</dd>
        }
        @if (Model.HasValue("endDate"))
        {
            <dt>End Date</dt>
            <dd>@Model.Value("endDate")</dd>
        }
        @if (Model.HasValue("instructor"))
        {
            <dt>Instructor</dt>
            <dd>@Model.Value("instructor")</dd>
        }
    </dl>
</div>
