@using Umbraco.Cms.Web.Common.PublishedModels
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@{
    Layout = "Master.cshtml";
}
<h1>@Model.Value("siteName")</h1>

@if (Model.HasValue("siteDescription"))
{
    <p class="lead">@Model.Value("siteDescription")</p>
}

@if (Model.HasValue("organisationName") || Model.HasValue("organisationEmail") || Model.HasValue("organisationTelephone"))
{
    <div class="card">
        <h2>Organisation</h2>
        <dl>
            @if (Model.HasValue("organisationName"))
            {
                <dt>Name</dt>
                <dd>@Model.Value("organisationName")</dd>
            }
            @if (Model.HasValue("organisationEmail"))
            {
                <dt>Email</dt>
                <dd><a href="mailto:@Model.Value("organisationEmail")">@Model.Value("organisationEmail")</a></dd>
            }
            @if (Model.HasValue("organisationTelephone"))
            {
                <dt>Telephone</dt>
                <dd>@Model.Value("organisationTelephone")</dd>
            }
        </dl>
    </div>
}

<h2>Explore Our Site</h2>
@if (Model.Children != null && Model.Children.Any())
{
    <div class="card-grid">
        @foreach (var child in Model.Children)
        {
            <div class="card">
                <h3><a href="@child.Url()">@child.Name</a></h3>
                @if (child.HasValue("description"))
                {
                    <p>@child.Value("description")</p>
                }
                else
                {
                    <p><span class="tag">@child.ContentType.Alias</span></p>
                }
            </div>
        }
    </div>
}